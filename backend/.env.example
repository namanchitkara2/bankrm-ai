# ── LLM Configuration ────────────────────────────────────────────────
# Choose one: gemini | ollama | nvidia
LLM_BACKEND=gemini

GEMINI_API_KEY=your_gemini_api_key_here
# Get from: https://aistudio.google.com/app/apikey

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:4b
# Run locally: https://ollama.com

NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_MODEL=meta/llama-3.1-70b-instruct
# Get free key: https://build.nvidia.com

# ── CRM Configuration ────────────────────────────────────────────────
CRM_BACKEND=sqlite
DATABASE_URL=sqlite:///./banking_crm.db

# ── Sender Backend ───────────────────────────────────────────────────
# whatsapp-web = free (your own WhatsApp via QR scan)
# twilio       = Twilio Content API with quick-reply buttons
# mock         = dev mode, no real messages sent
SENDER_BACKEND=whatsapp-web

# ── WhatsApp Web Service ─────────────────────────────────────────────
WHATSAPP_SERVICE_URL=http://localhost:3001

# ── Sandbox Mode ─────────────────────────────────────────────────────
# true  = all messages go to WHATSAPP_SANDBOX_NUMBER (safe for testing)
# false = messages go to actual customer CRM phone numbers
WHATSAPP_SANDBOX=true
WHATSAPP_SANDBOX_NUMBER=+91XXXXXXXXXX

# ── Twilio ───────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+14155238886
TWILIO_WHATSAPP_CONTENT_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Application ──────────────────────────────────────────────────────
DEBUG=false
PORT=8000
